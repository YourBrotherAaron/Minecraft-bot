<file path="src/services/FishingService.mjs">
import { Vec3 } from 'vec3'
import { sleep } from '../utils/sleep.mjs'

export class FishingService {
    constructor(ctx) {
        this.ctx = ctx
        this.busy = false
    }

    async runFishingCycle() {
        if (this.busy) return
        this.busy = true

        try {
            const rod = this.findFishingRod()
            if (!rod) {
                console.log('[fishing] no fishing rod found in inventory')
                return
            }

            const fishingSpot = this.findBestFishingSpot()
            if (!fishingSpot) {
                console.log('[fishing] no suitable fishing spot found nearby')
                return
            }

            console.log(
                `[fishing] using ${fishingSpot.quality} water at ${fishingSpot.waterBlock.position}`
            )

            await this.goToFishingSpot(fishingSpot.standPos)
            await this.ctx.bot.equip(rod, 'hand')
            await this.lookAtFishingSpot(fishingSpot.waterBlock)

            console.log('[fishing] casting line')
            await this.ctx.bot.fish()
            console.log('[fishing] caught something')

            await sleep(500)
        } catch (err) {
            console.log(`[fishing] runFishingCycle error: ${err.message}`)
        } finally {
            this.busy = false
        }
    }

    findFishingRod() {
        return this.ctx.services.inventory.findItemByName('fishing_rod')
    }

    findBestFishingSpot() {
        const bot = this.ctx.bot

        const positions = bot.findBlocks({
            maxDistance: 24,
            count: 100,
            matching: (block) => block && block.name === 'water'
        })

        const perfectCandidates = []
        const usableCandidates = []

        for (const pos of positions) {
            const waterBlock = bot.blockAt(pos)
            if (!waterBlock || !waterBlock.position) continue

            const standPos = this.findStandPositionForWater(waterBlock)
            if (!standPos) continue

            if (this.isPerfectFishingWater(waterBlock, standPos)) {
                perfectCandidates.push({ waterBlock, standPos, quality: 'perfect' })
                continue
            }

            if (this.isUsableFishingWater(waterBlock, standPos)) {
                usableCandidates.push({ waterBlock, standPos, quality: 'usable' })
            }
        }

        const nearestPerfect = this.getNearestCandidate(perfectCandidates)
        if (nearestPerfect) return nearestPerfect

        return this.getNearestCandidate(usableCandidates)
    }

    getNearestCandidate(candidates) {
        if (candidates.length === 0) return null

        const botPos = this.ctx.bot.entity.position

        candidates.sort((a, b) => {
            const distA = botPos.distanceTo(a.standPos)
            const distB = botPos.distanceTo(b.standPos)
            return distA - distB
        })

        return candidates[0]
    }

    findStandPositionForWater(waterBlock) {
        const directions = [
            new Vec3(1, 1, 0),
            new Vec3(-1, 1, 0),
            new Vec3(0, 1, 1),
            new Vec3(0, 1, -1)
        ]

        for (const dir of directions) {
            const standPos = waterBlock.position.plus(dir)

            if (!this.isStandableSpot(standPos)) continue
            if (this.hasCastObstructionFrom(standPos, waterBlock)) continue

            return standPos
        }

        return null
    }

    isStandableSpot(standPos) {
        const bot = this.ctx.bot

        const feet = bot.blockAt(standPos)
        const head = bot.blockAt(standPos.offset(0, 1, 0))
        const below = bot.blockAt(standPos.offset(0, -1, 0))

        if (!feet || feet.name !== 'air') return false
        if (!head || head.name !== 'air') return false
        if (!below) return false

        if (below.name === 'air' || below.name === 'water' || below.name === 'lava') {
            return false
        }

        return true
    }

    hasCastObstructionFrom(standPos, waterBlock) {
        const bot = this.ctx.bot
        const waterPos = waterBlock.position

        const dx = waterPos.x - standPos.x
        const dz = waterPos.z - standPos.z
        const steps = Math.max(Math.abs(dx), Math.abs(dz))

        if (steps === 0) return false

        for (let i = 1; i <= steps; i++) {
            const x = standPos.x + Math.round((dx * i) / steps)
            const z = standPos.z + Math.round((dz * i) / steps)

            const body = bot.blockAt(new Vec3(x, standPos.y, z))
            const head = bot.blockAt(new Vec3(x, standPos.y + 1, z))

            const blockedBody = body && body.name !== 'air' && body.name !== 'water'
            const blockedHead = head && head.name !== 'air' && head.name !== 'water'

            if (blockedBody || blockedHead) return true
        }

        return false
    }

    isUsableFishingWater(waterBlock, standPos) {
        if (!this.hasAirAboveWater(waterBlock)) return false
        if (this.hasCastObstructionFrom(standPos, waterBlock)) return false
        return true
    }

    hasAirAboveWater(block) {
        const bot = this.ctx.bot
        if (!block || block.name !== 'water') return false

        const above1 = bot.blockAt(block.position.offset(0, 1, 0))
        const above2 = bot.blockAt(block.position.offset(0, 2, 0))

        return above1?.name === 'air' && above2?.name === 'air'
    }

    isPerfectFishingWater(waterBlock, standPos) {
        if (!this.isUsableFishingWater(waterBlock, standPos)) return false

        const bot = this.ctx.bot
        const center = waterBlock.position

        // Approximate 5 x 4 x 5 check
        // x: -2..2, z: -2..2
        // y layers checked: -1, 0, +1, +2 relative to water block
        for (let dx = -2; dx <= 2; dx++) {
            for (let dz = -2; dz <= 2; dz++) {
                const lower = bot.blockAt(center.offset(dx, -1, dz))
                const water = bot.blockAt(center.offset(dx, 0, dz))
                const air1 = bot.blockAt(center.offset(dx, 1, dz))
                const air2 = bot.blockAt(center.offset(dx, 2, dz))

                if (!lower || lower.name !== 'water') return false
                if (!water || water.name !== 'water') return false
                if (!air1 || air1.name !== 'air') return false
                if (!air2 || air2.name !== 'air') return false
            }
        }

        return true
    }

    async goToFishingSpot(standPos) {
        await this.ctx.services.movement.goNear(standPos, 0.5)
        await sleep(500)
    }

    async lookAtFishingSpot(waterBlock) {
        const bot = this.ctx.bot
        const botPos = bot.entity.position
        const lookTarget = waterBlock.position.offset(0.5, 0.5, 0.5)

        const dx = lookTarget.x - botPos.x
        const dy = lookTarget.y - (botPos.y + bot.entity.height)
        const dz = lookTarget.z - botPos.z

        const yaw = Math.atan2(-dx, -dz)
        const groundDistance = Math.sqrt(dx * dx + dz * dz)
        const pitch = Math.atan2(dy, groundDistance)

        await bot.look(yaw, pitch, true)
        await sleep(200)
    }
}
