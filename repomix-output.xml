export class FisherRole extends BaseRole {
    constructor() {
        super('fisher')
    }

    async start(ctx) {
        await super.start(ctx)
        ctx.bot.chat('Fisher bot online')

        try {
            while (this.active && ctx.bot && ctx.bot.entity) {
                await ctx.services.fishing.runFishingCycle()
